<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Odoo 18: the purchase order form may not embed an inline <tree> under order_line.
        Therefore, we extend the purchase.order.line tree view directly.
    -->
    <record id="view_purchase_order_line_tree_recost" model="ir.ui.view">
        <field name="name">purchase.order.line.tree.recost</field>
        <field name="model">purchase.order.line</field>
        <field name="inherit_id" ref="purchase.purchase_order_line_tree"/>
        <field name="arch" type="xml">
            <!--
                Odoo 17+ switched many list views from <tree> to <list>.
                Use a union xpath to support both.
            -->
            <xpath expr="//tree | //list" position="inside">
                <field name="x_cost_gross_usd" optional="show"/>
                <field name="x_cost_ship_usd" optional="show"/>
                <field name="x_cost_gross_mxn" optional="show" readonly="1"/>
                <field name="x_cost_ship_mxn" optional="show" readonly="1"/>
                <field name="x_import_fixed_mxn" optional="show"/>
                <field name="x_cost_total_mxn" optional="show" readonly="1"/>
            </xpath>
        </field>
    </record>
</odoo>
