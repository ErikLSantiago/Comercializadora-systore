<odoo>
    <templates id="website_invitation_visibility_templates">
        <template id="invitation_denied_template" name="Invitación requerida">
            <t t-call="web.layout">
                <div class="container mt-5 mb-5">
                    <div class="alert alert-warning" role="alert">
                        <h3 class="mb-3">Acceso restringido</h3>
                        <p>Esta página está disponible <strong>solo por invitación</strong>.</p>
                        <p>Para acceder, tu contacto debe tener habilitado el campo <strong>Acceso Mayoristas</strong>.</p>
                        <t t-if="request.env.user._is_public()">
                            <p><a class="btn btn-primary" t-attf-href="/web/login?redirect={{ request.httprequest.path }}">Iniciar sesión</a></p>
                        </t>
                        <t t-if="not request.env.user._is_public()">
                            <p>Contacta a tu administrador si necesitas acceso.</p>
                        </t>
                    </div>
                </div>
            </t>
        </template>
    </templates>
</odoo>
