<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_purchase_order_form_recost" model="ir.ui.view">
        <field name="name">purchase.order.form.recost</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button
                    name="action_recostear"
                    type="object"
                    string="Recostear"
                    class="btn-primary"
                    groups="purchase.group_purchase_user"
                    attrs="{'invisible': [('state', 'not in', ('draft','sent','to approve','purchase'))]}"
                />
            </xpath>

            <xpath expr="//field[@name='currency_id']" position="after">
                <field name="x_exchange_rate" groups="purchase.group_purchase_user" placeholder="Ej. 17.5000"/>
            </xpath>
        </field>
    </record>
</odoo>
