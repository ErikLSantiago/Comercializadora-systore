<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_income_account" model="ir.ui.view">
        <field name="name">res.partner.form.income.account</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="account.view_partner_property_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='accounting']/group" position="inside">
                <field name="systore_income_account_id"
                       groups="account.group_account_user"/>
            </xpath>
        </field>
    </record>
</odoo>
