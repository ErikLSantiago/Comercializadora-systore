<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_product_template_form_import_fixed" model="ir.ui.view">
        <field name="name">product.template.form.import.fixed</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <!-- Insert field in Purchase tab if present; otherwise it will be added near general information -->
            <xpath expr="//page[@name='purchase']/group" position="inside">
                <group string="Importación">
                    <field name="x_import_fixed_mxn" groups="purchase.group_purchase_user"/>
                </group>
            </xpath>
            <xpath expr="//sheet//group" position="inside">
                <group string="Importación" groups="purchase.group_purchase_user">
                    <field name="x_import_fixed_mxn"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
