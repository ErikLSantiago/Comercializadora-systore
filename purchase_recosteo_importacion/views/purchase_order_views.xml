<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Custom list view for cost breakdown in the new tab -->
    <record id="view_purchase_order_line_list_cost_breakdown" model="ir.ui.view">
        <field name="name">purchase.order.line.list.cost.breakdown</field>
        <field name="model">purchase.order.line</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="product_id"/>
                <field name="product_qty"/>
                <field name="price_unit" string="Precio (nativo)"/>
                <field name="x_gross_usd"/>
                <field name="x_ship_usd"/>
                <field name="x_gross_mxn"/>
                <field name="x_ship_mxn"/>
                <field name="x_import_mxn"/>
                <field name="x_calc_price_mxn"/>
            </list>
        </field>
    </record>

    <!-- Purchase order form: add exchange rate, Recostear button, and new tab -->
    <record id="view_purchase_order_form_cost_breakdown" model="ir.ui.view">
        <field name="name">purchase.order.form.cost.breakdown</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="priority">90</field>
        <field name="arch" type="xml">
            <!-- Exchange rate in header -->
            <xpath expr="//group[.//field[@name='currency_id']]" position="inside">
                <field name="x_exchange_rate"/>
            </xpath>

            <!-- Recostear button -->
            <xpath expr="//header" position="inside">
                <button name="action_recostear" type="object" string="Recostear" class="btn-primary" invisible="state in ('done','cancel')"/>
            </xpath>

            <!-- New tab in notebook -->
            <xpath expr="//notebook" position="inside">
                <page string="Desglose costos" name="cost_breakdown">
                    <group>
                        <div class="o_form_label">Captura los costos unitarios en USD, revisa su conversión a MXN y presiona Recostear para impactar el precio unitario nativo.</div>
                    </group>
                    <field name="order_line" context="{'list_view_ref': 'purchase_recosteo_importacion.view_purchase_order_line_list_cost_breakdown'}" mode="list"/>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
