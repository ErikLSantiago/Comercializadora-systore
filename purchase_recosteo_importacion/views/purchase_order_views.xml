<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_purchase_order_form_recost" model="ir.ui.view">
        <field name="name">purchase.order.form.recost</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button
                    name="action_recostear"
                    type="object"
                    string="Recostear"
                    class="btn-primary"
                    groups="purchase.group_purchase_user"
                    attrs="{'invisible': [('state', 'not in', ('draft','sent','to approve','purchase'))]}"
                />
            </xpath>

            <xpath expr="//field[@name='currency_id']" position="after">
                <field name="x_exchange_rate" groups="purchase.group_purchase_user" placeholder="Ej. 17.5000"/>
            </xpath>

            <!--
                Odoo 18 purchase order line tree structure can vary depending on localization/enterprise.
                To avoid brittle xpaths (e.g. targeting price_unit which may be removed/replaced),
                we inject our columns at the end of the order_line tree.
            -->
            <xpath expr="//field[@name='order_line']//tree" position="inside">
                <field name="x_cost_gross_usd" optional="show"/>
                <field name="x_cost_ship_usd" optional="show"/>
                <field name="x_cost_gross_mxn" optional="show" readonly="1"/>
                <field name="x_cost_ship_mxn" optional="show" readonly="1"/>
                <field name="x_import_fixed_mxn" optional="show"/>
                <field name="x_cost_total_mxn" optional="show" readonly="1"/>
            </xpath>
        </field>
    </record>
</odoo>
