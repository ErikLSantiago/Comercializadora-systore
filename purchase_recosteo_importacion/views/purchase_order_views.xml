<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_purchase_order_form_recost" model="ir.ui.view">
        <field name="name">purchase.order.form.recost</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button
                    name="action_recostear"
                    type="object"
                    string="Recostear"
                    class="btn-primary"
                    groups="purchase.group_purchase_user"
                />
            </xpath>

            <xpath expr="//field[@name='currency_id']" position="after">
                <field name="x_exchange_rate" groups="purchase.group_purchase_user" placeholder="Ej. 17.5000"/>
            </xpath>

            <!-- Force the one2many list view for order_line to our dedicated view so the columns are always available -->
            <xpath expr="//field[@name='order_line']" position="attributes">
                <attribute name="context">{'tree_view_ref': 'purchase_recosteo_importacion.view_purchase_order_line_list_recost_base', 'list_view_ref': 'purchase_recosteo_importacion.view_purchase_order_line_list_recost_base'}</attribute>
            </xpath>
        </field>
    </record>
</odoo>
